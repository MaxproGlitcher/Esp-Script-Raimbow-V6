local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local lpr = Players.LocalPlayer
local camera = Workspace.CurrentCamera

local espEnabled = true
local teamCheckActive = false
local skeletonEnabled = true
local healthBarEnabled = true

local toggleE = Enum.KeyCode.E
local toggleR = Enum.KeyCode.R
local toggleT = Enum.KeyCode.T
local toggleY = Enum.KeyCode.Y

local playerTracers = {}
local playerInfoTexts = {}
local playerHitboxes = {}
local playerSkeletons = {}
local playerHealthBars = {}

local function rainbowColor()
    local t = tick() * 8
    return Color3.fromRGB(
        math.floor(math.sin(t) * 127 + 128),
        math.floor(math.sin(t + 2) * 127 + 128),
        math.floor(math.sin(t + 4) * 127 + 128)
    )
end

local function getCharacterParts(character)
    if not character then return end
    local root = character:FindFirstChild("HumanoidRootPart") or character.PrimaryPart
    local head = character:FindFirstChild("Head")
    if not head then
        for _, v in ipairs(character:GetChildren()) do
            if v:IsA("BasePart") and v.Name:lower():find("head") then 
                head = v 
                break 
            end
        end
    end
    return root, head, character:FindFirstChildOfClass("Humanoid")
end

local function createHealthBar()
    local barBG = Drawing.new("Square")
    local barFG = Drawing.new("Square")
    barBG.Thickness = 1
    barBG.Filled = true
    barBG.Color = Color3.new(0, 0, 0)
    barBG.Transparency = 0.5
    
    barFG.Thickness = 1
    barFG.Filled = true
    barFG.Transparency = 1
    return {bg = barBG, fg = barFG}
end

local function updateHealthBar(character, healthBar, humanoid, headPos, onScreen)
    if not healthBarEnabled or not onScreen then
        healthBar.bg.Visible = false
        healthBar.fg.Visible = false
        return
    end

    local health = humanoid and humanoid.Health or 100
    local maxHealth = humanoid and humanoid.MaxHealth or 100
    local percent = health / maxHealth

    local barWidth = 4
    local barHeight = 30
    local x = headPos.X - barWidth/2 - 20
    local y = headPos.Y - barHeight/2

    healthBar.bg.Size = Vector2.new(barWidth, barHeight)
    healthBar.bg.Position = Vector2.new(x, y)
    healthBar.bg.Visible = true

    healthBar.fg.Size = Vector2.new(barWidth, barHeight * percent)
    healthBar.fg.Position = Vector2.new(x, y + barHeight * (1 - percent))
    healthBar.fg.Color = rainbowColor()
    healthBar.fg.Visible = true
end

local function createSkeleton()
    local skel = {}
    for i = 1, 12 do
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Transparency = 1
        table.insert(skel, line)
    end
    return skel
end

local function updateSkeleton(character, skeleton)
    if not skeletonEnabled then
        for _, l in ipairs(skeleton) do l.Visible = false end
        return
    end

    local root, head = getCharacterParts(character)
    if not root or not head then return end

    local parts = {
        Head = head,
        UpperTorso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"),
        LowerTorso = character:FindFirstChild("LowerTorso") or character:FindFirstChild("Torso"),
        LeftUpperArm = character:FindFirstChild("LeftUpperArm") or character:FindFirstChild("Left Arm"),
        RightUpperArm = character:FindFirstChild("RightUpperArm") or character:FindFirstChild("Right Arm"),
        LeftUpperLeg = character:FindFirstChild("LeftUpperLeg") or character:FindFirstChild("Left Leg"),
        RightUpperLeg = character:FindFirstChild("RightUpperLeg") or character:FindFirstChild("Right Leg"),
    }

    local color = rainbowColor()
    local connections = {
        {parts.Head, parts.UpperTorso},
        {parts.UpperTorso, parts.LowerTorso},
        {parts.UpperTorso, parts.LeftUpperArm},
        {parts.UpperTorso, parts.RightUpperArm},
        {parts.LowerTorso, parts.LeftUpperLeg},
        {parts.LowerTorso, parts.RightUpperLeg},
    }

    local i = 1
    for _, conn in ipairs(connections) do
        local p1, p2 = conn[1], conn[2]
        if p1 and p2 then
            local pos1 = camera:WorldToViewportPoint(p1.Position)
            local pos2 = camera:WorldToViewportPoint(p2.Position)
            local line = skeleton[i]
            if pos1.Z > 0 and pos2.Z > 0 then
                line.From = Vector2.new(pos1.X, pos1.Y)
                line.To = Vector2.new(pos2.X, pos2.Y)
                line.Color = color
                line.Visible = true
            else
                line.Visible = false
            end
            i += 1
        end
    end
end

local function updateESP()
    if not espEnabled then
        for _, v in pairs(playerTracers) do v.Visible = false end
        for _, v in pairs(playerInfoTexts) do if v.gui then v.gui.Enabled = false end end
        for _, v in pairs(playerHitboxes) do v.Visible = false end
        for _, v in pairs(playerSkeletons) do 
            for _, l in ipairs(v) do l.Visible = false end 
        end
        for _, v in pairs(playerHealthBars) do 
            v.bg.Visible = false 
            v.fg.Visible = false 
        end
        return
    end

    local myRoot = lpr.Character and (lpr.Character:FindFirstChild("HumanoidRootPart") or lpr.Character.PrimaryPart)
    if not myRoot then return end

    for _, character in ipairs(Workspace:GetChildren()) do
        if character:IsA("Model") and character ~= lpr.Character then
            local root, head, humanoid = getCharacterParts(character)
            if not root or not head then continue end

            if teamCheckActive then
                local plr = Players:GetPlayerFromCharacter(character)
                if plr and plr.Team == lpr.Team then continue end
            end

            local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)
            local headPos, headOnScreen = camera:WorldToViewportPoint(head.Position)

            if not playerTracers[character] then 
                playerTracers[character] = Drawing.new("Line") 
                playerTracers[character].Thickness = 2 
            end
            if not playerHitboxes[character] then 
                playerHitboxes[character] = Drawing.new("Square")
                playerHitboxes[character].Thickness = 2 
            end
            if not playerSkeletons[character] then 
                playerSkeletons[character] = createSkeleton() 
            end
            if not playerHealthBars[character] then 
                playerHealthBars[character] = createHealthBar() 
            end

            local tracer = playerTracers[character]
            local hitbox = playerHitboxes[character]

            if onScreen then
                tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                tracer.Color = rainbowColor()
                tracer.Visible = true

                if headOnScreen then
                    local size = (headPos - screenPos).Magnitude * 2.4
                    hitbox.Size = Vector2.new(size, size * 2.8)
                    hitbox.Position = Vector2.new(screenPos.X - size/2, screenPos.Y - size*1.4)
                    hitbox.Color = rainbowColor()
                    hitbox.Visible = true

                    updateHealthBar(character, playerHealthBars[character], humanoid, headPos, true)
                else
                    hitbox.Visible = false
                    playerHealthBars[character].bg.Visible = false
                    playerHealthBars[character].fg.Visible = false
                end

                updateSkeleton(character, playerSkeletons[character])
            else
                tracer.Visible = false
                hitbox.Visible = false
                for _, l in ipairs(playerSkeletons[character]) do l.Visible = false end
                playerHealthBars[character].bg.Visible = false
                playerHealthBars[character].fg.Visible = false
            end
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == toggleE then
        teamCheckActive = not teamCheckActive
    elseif input.KeyCode == toggleR then
        espEnabled = not espEnabled
    elseif input.KeyCode == toggleT then
        skeletonEnabled = not skeletonEnabled
    elseif input.KeyCode == toggleY then
        healthBarEnabled = not healthBarEnabled
    end
end)

RunService.RenderStepped:Connect(updateESP)
