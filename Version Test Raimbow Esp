        for _, v in pairs(playerElements) do for _, obj in pairs(v) do obj.Visible = false end end
        return
    end

    local t = tick()

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then continue end

        local shouldRender = ESP.TeamMode == "All" or
                           (ESP.TeamMode == "Enemies" and player.Team ~= LocalPlayer.Team) or
                           (ESP.TeamMode == "Allies" and player.Team == LocalPlayer.Team)

