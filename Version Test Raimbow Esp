local function shouldShow(player)
    if not ESP.Enabled then return false end
    if player == LocalPlayer then return false end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return false end

    if ESP.TeamMode == "Enemies" and player.Team == LocalPlayer.Team then return false end
    if ESP.TeamMode == "Allies" and player.Team ~= LocalPlayer.Team then return false end
    return true
end

local function updateESP()
    local time = tick()

    for _, player in ipairs(Players:GetPlayers()) do
        if not shouldShow(player) then
            if playerTracers[player] then playerTracers[player].Visible = false end
            if playerBillboards[player] then playerBillboards[player].Enabled = false end
            if playerBoxes[player] then playerBoxes[player].Visible = false end
            continue
        end

        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")
        if not root or not head then continue end

        local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)
        local headPos = Camera:WorldToViewportPoint(head.Position)

        -- Tracers
        if ESP.Tracers then
            if not playerTracers[player] then
                playerTracers[player] = Drawing.new("Line")
                playerTracers[player].Thickness = ESP.TracerThickness
                playerTracers[player].Transparency = 1
            end
            local tracer = playerTracers[player]
            tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            tracer.To = Vector2.new(rootPos.X, rootPos.Y)
            tracer.Color = ESP.Rainbow and rainbowColor(time + player.UserId) or Color3.fromRGB(255, 50, 50)
            tracer.Thickness = ESP.TracerThickness
            tracer.Visible = onScreen
        elseif playerTracers[player] then
            playerTracers[player].Visible = false
        end

        -- Billboard Info
        if ESP.Info then
            if not playerBillboards[player] then
                local billboard = Instance.new("BillboardGui")
                billboard.Size = UDim2.new(0, 200, 0, 80)
                billboard.StudsOffset = Vector3.new(0, ESP.BillboardOffset, 0)
                billboard.AlwaysOnTop = true
                billboard.Adornee = root
                billboard.Parent = root

                local name = Instance.new("TextLabel", billboard)
                name.Size = UDim2.new(1,0,0.33,0)
                name.BackgroundTransparency = 1
                name.Text = player.Name
                name.TextColor3 = Color3.new(1,1,1)
                name.TextStrokeTransparency = 0
                name.TextScaled = true
                name.Font = Enum.Font.GothamBold

                local dist = Instance.new("TextLabel", billboard)
                dist.Size = UDim2.new(1,0,0.33,0)
                dist.Position = UDim2.new(0,0,0.33,0)
                dist.BackgroundTransparency = 1
                dist.TextScaled = true
                dist.Font = Enum.Font.Gotham

                local health = Instance.new("TextLabel", billboard)
                health.Size = UDim2.new(1,0,0.33,0)
                health.Position = UDim2.new(0,0,0.66,0)
                health.BackgroundTransparency = 1
                health.TextScaled = true
                health.Font = Enum.Font.Gotham

                playerBillboards[player] = {Gui = billboard, Dist = dist, Health = health}
            end

            local info = playerBillboards[player]
            info.Gui.Enabled = onScreen
            info.Gui.StudsOffset = Vector3.new(0, ESP.BillboardOffset, 0)

            local humanoid = char:FindFirstChildOfClass("Humanoid")
            local distance = (root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude

            info.Dist.Text = string.format("Distance: %.1f", distance)
            info.Health.Text = string.format("Health: %.0f", humanoid and humanoid.Health or 0)

            if ESP.Rainbow then
                local col = rainbowColor(time + player.UserId)
                info.Dist.TextColor3 = col
                info.Health.TextColor3 = col
                info.Gui.TextLabel.TextColor3 = col -- name
            end
        elseif playerBillboards[player] then
            playerBillboards[player].Gui.Enabled = false
        end

        -- Box
        if ESP.Boxes and onScreen then
            if not playerBoxes[player] then
                playerBoxes[player] = Drawing.new("Square")
                playerBoxes[player].Thickness = 2
                playerBoxes[player].Transparency = 1
                playerBoxes[player].Filled = false
            end
            local box = playerBoxes[player]
            local size = (headPos - rootPos).Magnitude * 2.2 * ESP.BoxSizeMultiplier
            box.Size = Vector2.new(size, size * 2.8)
            box.Position = Vector2.new(rootPos.X - size/2, rootPos.Y - size*1.4)
            box.Color = ESP.Rainbow and rainbowColor(time + player.UserId) or Color3.fromRGB(255, 50, 50)
            box.Visible = true
        elseif playerBoxes[player] then
            playerBoxes[player].Visible = false
        end
    end
end

