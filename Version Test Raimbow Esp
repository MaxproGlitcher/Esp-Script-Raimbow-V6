local Tracers, Boxes, Billboards = {}, {}, {}

local function rainbow(freq) 
    return Color3.fromRGB(
        math.floor(math.sin(freq)*127 + 128),
        math.floor(math.sin(freq+2)*127 + 128),
        math.floor(math.sin(freq+4)*127 + 128)
    )
end

local function updateESP()
    if not ESP.Enabled then return end
    local t = tick()

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end

        local root = player.Character:FindFirstChild("HumanoidRootPart")
        local head = player.Character:FindFirstChild("Head")
        if not root or not head then continue end

        local shouldShow = ESP.TeamMode == "All" or
                          (ESP.TeamMode == "Enemies" and player.Team ~= LocalPlayer.Team) or
                          (ESP.TeamMode == "Allies" and player.Team == LocalPlayer.Team)

        if not shouldShow then continue end

        local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)

        -- Tracers
        if ESP.Tracers and onScreen then
            if not Tracers[player] then Tracers[player] = Drawing.new("Line") end
            local line = Tracers[player]
            line.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            line.To = Vector2.new(rootPos.X, rootPos.Y)
            line.Color = ESP.Rainbow and rainbow(t + player.UserId) or Color3.fromRGB(255, 50, 50)
            line.Thickness = ESP.TracerThickness
            line.Transparency = 1
            line.Visible = true
        elseif Tracers[player] then Tracers[player].Visible = false end

        -- Boxes
        if ESP.Boxes and onScreen then
            if not Boxes[player] then Boxes[player] = Drawing.new("Square") end
            local box = Boxes[player]
            local size = (Camera:WorldToViewportPoint(head.Position) - rootPos).Magnitude * 2.4 * ESP.BoxMultiplier
            box.Size = Vector2.new(size, size * 2.6)
            box.Position = Vector2.new(rootPos.X - size/2, rootPos.Y - size * 1.35)
            box.Color = ESP.Rainbow and rainbow(t + player.UserId) or Color3.fromRGB(255, 50, 50)
            box.Thickness = 2
            box.Transparency = 1
            box.Filled = false
            box.Visible = true
        elseif Boxes[player] then Boxes[player].Visible = false end

        -- Info
        if ESP.Info then
            if not Billboards[player] then
                local bg = Instance.new("BillboardGui")
                bg.Size = UDim2.new(0, 220, 0, 90)
                bg.StudsOffset = Vector3.new(0, ESP.BillboardOffset, 0)
                bg.AlwaysOnTop = true
                bg.Adornee = root
                bg.Parent = root

                -- Name, Distance, Health (simplifié)
                local name = Instance.new("TextLabel", bg)
                name.Size = UDim2.new(1,0,0.4,0)
                name.BackgroundTransparency = 1
                name.Text = player.Name
                name.TextColor3 = Color3.fromRGB(255,255,255)
                name.TextScaled = true
                name.Font = Enum.Font.GothamBold

                Billboards[player] = bg
            end
            Billboards[player].Enabled = onScreen
            Billboards[player].StudsOffset = Vector3.new(0, ESP.BillboardOffset, 0)
        end
    end
end

