local function AddToggle(parent, name, default, callback)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, -10, 0, 60)
    f.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    f.Parent = parent
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.7, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = name
    lbl.TextColor3 = Color3.fromRGB(255,255,255)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextSize = 17
    lbl.Font = Enum.Font.GothamSemibold
    lbl.Parent = f

    local switch = Instance.new("Frame")
    switch.Size = UDim2.new(0, 70, 0, 34)
    switch.Position = UDim2.new(1, -85, 0.5, -17)
    switch.BackgroundColor3 = default and Color3.fromRGB(140, 60, 255) or Color3.fromRGB(60, 60, 70)
    switch.Parent = f
    Instance.new("UICorner", switch).CornerRadius = UDim.new(1, 0)

    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 28, 0, 28)
    circle.Position = UDim2.new(0, default and 38 or 4, 0.5, -14)
    circle.BackgroundColor3 = Color3.fromRGB(255,255,255)
    circle.Parent = switch
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)

    local state = default
    f.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            state = not state
            callback(state)
            TweenService:Create(switch, TweenInfo.new(0.25), {BackgroundColor3 = state and Color3.fromRGB(140, 60, 255) or Color3.fromRGB(60,60,70)}):Play()
            TweenService:Create(circle, TweenInfo.new(0.25), {Position = UDim2.new(0, state and 38 or 4, 0.5, -14)}):Play()
        end
    end)
end

