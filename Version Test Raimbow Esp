-- Rainbow Function
local function rainbowColor(freq)
    local r = math.floor(math.sin(freq + 0) * 127 + 128)
    local g = math.floor(math.sin(freq + 2) * 127 + 128)
    local b = math.floor(math.sin(freq + 4) * 127 + 128)
    return Color3.fromRGB(r, g, b)
end

