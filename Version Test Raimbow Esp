local function AddTeamButton(text, mode)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 35)
    btn.Position = UDim2.new(0, 10, 0, (mode == "All" and 10 or mode == "Enemies" and 50 or 90))
    btn.BackgroundColor3 = ESP.TeamMode == mode and Color3.fromRGB(80, 140, 255) or Color3.fromRGB(45,45,45)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = TeamFrame
    btn.MouseButton1Click:Connect(function()
        ESP.TeamMode = mode
        for _, b in pairs(TeamFrame:GetChildren()) do
            if b:IsA("TextButton") then
                b.BackgroundColor3 = (b.Text == text) and Color3.fromRGB(80, 140, 255) or Color3.fromRGB(45,45,45)
            end
        end
    end)
end

