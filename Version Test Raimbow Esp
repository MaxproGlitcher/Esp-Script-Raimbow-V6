Players.PlayerRemoving:Connect(function(plr)
    if playerTracers[plr] then playerTracers[plr]:Remove() end
    if playerBillboards[plr] then playerBillboards[plr].Gui:Destroy() end
    if playerBoxes[plr] then playerBoxes[plr]:Remove() end
end)

