
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local lpr = Players.LocalPlayer
local camera = Workspace.CurrentCamera
local worldToViewportPoint = camera.WorldToViewportPoint

local teamMode = 0
local toggleKey = Enum.KeyCode.E
local toggleRKey = Enum.KeyCode.R
local toggleHealthBarKey = Enum.KeyCode.T
local toggleXRayKey = Enum.KeyCode.Y     

local espEnabled = true
local healthBarEnabled = true
local xrayEnabled = false

local function rainbowColor(frequency)
    local r = math.floor(math.sin(frequency + 0) * 127 + 128)
    local g = math.floor(math.sin(frequency + 2) * 127 + 128)
    local b = math.floor(math.sin(frequency + 4) * 127 + 128)
    return Color3.fromRGB(r, g, b)
end

local playerTracers = {}
local playerInfoTexts = {}
local playerHitboxes = {}
local playerHealthBars = {}

local function getTeamModeText()
    if teamMode == 1 then return "Ennemis seulement"
    elseif teamMode == 2 then return "Équipe seulement"
    else return "Tout le monde" end
end


local function applyXRay()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            local character = v.Parent
            if character and character:FindFirstChildWhichIsA("Humanoid") then
                -- Ne pas appliquer sur les personnages
            elseif character and character.Parent and character.Parent:FindFirstChildWhichIsA("Humanoid") then
                -- Ne pas appliquer sur les personnages
            else
                v.LocalTransparencyModifier = xrayEnabled and 0.7 or 0
            end
        end
    end
end


local function createBillboardGui(player)
    local billboardGui = Instance.new("BillboardGui")
    billboardGui.Size = UDim2.new(0, 200, 0, 75)
    billboardGui.StudsOffset = Vector3.new(0, 3, 0)
    billboardGui.AlwaysOnTop = true

    local nameLabel = Instance.new("TextLabel", billboardGui)
    nameLabel.Size = UDim2.new(1, 0, 0.33, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = rainbowColor(0)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextSize = 14
    nameLabel.Text = player.Name

    local distanceLabel = Instance.new("TextLabel", billboardGui)
    distanceLabel.Position = UDim2.new(0, 0, 0.33, 0)
    distanceLabel.Size = UDim2.new(1, 0, 0.33, 0)
    distanceLabel.BackgroundTransparency = 1
    distanceLabel.TextColor3 = rainbowColor(0)
    distanceLabel.TextStrokeTransparency = 0
    distanceLabel.TextSize = 14

    local healthLabel = Instance.new("TextLabel", billboardGui)
    healthLabel.Position = UDim2.new(0, 0, 0.66, 0)
    healthLabel.Size = UDim2.new(1, 0, 0.33, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.TextColor3 = rainbowColor(0)
    healthLabel.TextStrokeTransparency = 0
    healthLabel.TextSize = 14

    return billboardGui, nameLabel, distanceLabel, healthLabel
end

local function createHealthBar()
    local bg = Drawing.new("Square")
    local bar = Drawing.new("Square")
    
    bg.Thickness = 1
    bg.Filled = true
    bg.Color = Color3.fromRGB(0, 0, 0)
    bg.Transparency = 0.5
    
    bar.Thickness = 1
    bar.Filled = true
    bar.Transparency = 1
    
    return {bg = bg, bar = bar}
end

local function updatePlayerInfo(player, distanceLabel, healthLabel, time)
    local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
    if rootPart and lpr.Character and lpr.Character:FindFirstChild("HumanoidRootPart") then
        local distance = (rootPart.Position - lpr.Character.HumanoidRootPart.Position).Magnitude
        distanceLabel.Text = string.format("Distance : %.2f", distance)
        distanceLabel.TextColor3 = rainbowColor(time + player.UserId)
    end

    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        healthLabel.Text = string.format("Santé : %.0f", humanoid.Health)
        healthLabel.TextColor3 = rainbowColor(time + player.UserId)
    end
end

local function updateHealthBar(player, healthBar, headPos, headOnScreen, time)
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid or not headOnScreen then
        healthBar.bg.Visible = false
        healthBar.bar.Visible = false
        return
    end

    local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
    local barWidth = 60
    local barHeight = 6
    local offsetY = -25

    local screenPos = Vector2.new(headPos.X, headPos.Y + offsetY)

    healthBar.bg.Size = Vector2.new(barWidth, barHeight)
    healthBar.bg.Position = Vector2.new(screenPos.X - barWidth/2, screenPos.Y)
    healthBar.bg.Visible = true

    healthBar.bar.Size = Vector2.new(barWidth * healthPercent, barHeight)
    healthBar.bar.Position = Vector2.new(screenPos.X - barWidth/2, screenPos.Y)
    healthBar.bar.Color = rainbowColor(time + player.UserId)
    healthBar.bar.Visible = true
end

local function createHitbox()
    local hitbox = Drawing.new("Square")
    hitbox.Thickness = 2
    hitbox.Transparency = 1
    return hitbox
end

local function shouldShowPlayer(player)
    if teamMode == 0 then return true end
    if teamMode == 1 then return player.Team ~= lpr.Team end
    if teamMode == 2 then return player.Team == lpr.Team end
    return true
end

local function update()
    if not espEnabled or not lpr.Character or not lpr.Character:FindFirstChild("HumanoidRootPart") then
        for _, v in pairs(playerTracers) do v.Visible = false end
        for _, v in pairs(playerInfoTexts) do v.gui.Enabled = false end
        for _, v in pairs(playerHitboxes) do v.Visible = false end
        for _, v in pairs(playerHealthBars) do 
            v.bg.Visible = false 
            v.bar.Visible = false 
        end
        return
    end

    local time = tick()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= lpr and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            -- (Le reste du code ESP reste identique)
            local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
            local head = player.Character:FindFirstChild("Head")
            local screenPos, onScreen = worldToViewportPoint(camera, rootPart.Position)
            local headPos, headOnScreen = worldToViewportPoint(camera, head.Position)

            if not shouldShowPlayer(player) then
                if playerTracers[player] then playerTracers[player].Visible = false end
                if playerInfoTexts[player] then playerInfoTexts[player].gui.Enabled = false end
                if playerHitboxes[player] then playerHitboxes[player].Visible = false end
                if playerHealthBars[player] then
                    playerHealthBars[player].bg.Visible = false
                    playerHealthBars[player].bar.Visible = false
                end
            else
                if not playerTracers[player] then playerTracers[player] = Drawing.new("Line") end
                if not playerInfoTexts[player] then
                    local bg, name, dist, hp = createBillboardGui(player)
                    bg.Parent = player.Character:WaitForChild("HumanoidRootPart")
                    playerInfoTexts[player] = { gui = bg, name = name, distance = dist, health = hp }
                end
                if not playerHitboxes[player] then playerHitboxes[player] = createHitbox() end
                if not playerHealthBars[player] then playerHealthBars[player] = createHealthBar() end

                local tracer = playerTracers[player]
                local info = playerInfoTexts[player]
                local hitbox = playerHitboxes[player]
                local healthBar = playerHealthBars[player]

                if onScreen then
                    tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                    tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                    tracer.Color = rainbowColor(time + player.UserId)
                    tracer.Thickness = 2
                    tracer.Transparency = 1
                    tracer.Visible = true

                    if headOnScreen then
                        updatePlayerInfo(player, info.distance, info.health, time)
                        info.gui.Enabled = true
                        info.gui.StudsOffset = Vector3.new(0, 3, 0)
                        info.name.TextColor3 = rainbowColor(time + player.UserId)

                        local hitboxSize = (headPos - screenPos).Magnitude * 2
                        hitbox.Size = Vector2.new(hitboxSize, hitboxSize * 2.5)
                        hitbox.Position = Vector2.new(screenPos.X - hitboxSize / 2, screenPos.Y - hitboxSize * 1.25)
                        hitbox.Color = rainbowColor(time + player.UserId)
                        hitbox.Visible = true

                        if healthBarEnabled then
                            updateHealthBar(player, healthBar, headPos, headOnScreen, time)
                        else
                            healthBar.bg.Visible = false
                            healthBar.bar.Visible = false
                        end
                    else
                        info.gui.Enabled = false
                        hitbox.Visible = false
                        healthBar.bg.Visible = false
                        healthBar.bar.Visible = false
                    end
                else
                    tracer.Visible = false
                    info.gui.Enabled = false
                    hitbox.Visible = false
                    healthBar.bg.Visible = false
                    healthBar.bar.Visible = false
                end
            end
        end
    end
end


UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == toggleKey then
        teamMode = (teamMode + 1) % 3
        print("Mode équipe : " .. getTeamModeText())
    elseif input.KeyCode == toggleRKey then
        espEnabled = not espEnabled
    elseif input.KeyCode == toggleHealthBarKey then
        healthBarEnabled = not healthBarEnabled
    elseif input.KeyCode == toggleXRayKey then
        xrayEnabled = not xrayEnabled
        applyXRay()
        print("X-Ray : " .. (xrayEnabled and "Activé" or "Désactivé"))
    end
end)


local function onPlayerAdded(player)
    player.CharacterAdded:Connect(function()
        task.wait(1)
        if playerTracers[player] then playerTracers[player]:Remove() playerTracers[player] = nil end
        if playerInfoTexts[player] then 
            playerInfoTexts[player].gui:Destroy() 
            playerInfoTexts[player] = nil 
        end
        if playerHitboxes[player] then playerHitboxes[player]:Remove() playerHitboxes[player] = nil end
        if playerHealthBars[player] then
            playerHealthBars[player].bg:Remove()
            playerHealthBars[player].bar:Remove()
            playerHealthBars[player] = nil
        end
    end)
end

Players.PlayerAdded:Connect(onPlayerAdded)
RunService.RenderStepped:Connect(update)

Players.PlayerRemoving:Connect(function(player)
    if playerTracers[player] then playerTracers[player]:Remove() playerTracers[player] = nil end
    if playerInfoTexts[player] then playerInfoTexts[player].gui:Destroy() playerInfoTexts[player] = nil end
    if playerHitboxes[player] then playerHitboxes[player]:Remove() playerHitboxes[player] = nil end
    if playerHealthBars[player] then
        playerHealthBars[player].bg:Remove()
        playerHealthBars[player].bar:Remove()
        playerHealthBars[player] = nil
    end
end)

for _, player in pairs(Players:GetPlayers()) do
    onPlayerAdded(player)
end
